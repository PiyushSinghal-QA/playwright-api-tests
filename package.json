{
  "name": "playwright-api-tests",
  "version": "1.0.0",
  "description": "Modern API test automation framework using Playwright's native request context with TypeScript, JSON schema validation, and CI/CD integration",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps"
  },
  "keywords": [
    "playwright",
    "api-testing",
    "typescript",
    "rest-api",
    "automation",
    "json-schema",
    "ci-cd"
  ],
  "author": "Piyush Singhal",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.5",
    "typescript": "^5.6.0"
  }
}
